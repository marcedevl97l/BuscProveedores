# ── Clave secreta de Flask (cambia esto en produccion) ──────────────────────
FLASK_SECRET_KEY=cambia_esta_clave_secreta

# ── Ruta de la base de datos (opcional, por defecto usa db.sqlite en la raiz) ─
# DB_PATH=C:\ruta\personalizada\db.sqlite

# ── Credenciales Farmacom ────────────────────────────────────────────────────
FARMACOM_USER=tu_usuario_farmacom
FARMACOM_PASS=tu_contrasena_farmacom

# ── Modo del navegador para scraping ────────────────────────────────────────
# true  = oculto (recomendado para uso normal)
# false = visible (util para depuracion)
FARMACOM_HEADLESS=true

# ── Usuario administrador por defecto ───────────────────────────────────────
DEFAULT_ADMIN_USER=SUPERVISOR
DEFAULT_ADMIN_PASS=cambia_esta_contrasena
